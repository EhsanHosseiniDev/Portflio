---
import '~/styles/global.css';
import Navigation from '~/components/Navigation.astro';
import Footer from '~/components/Footer.astro';
import { getLangFromUrl, useTranslations, type Lang } from '~/i18n/ui';

interface Props {
  title: string;
  description?: string;
  lang?: Lang;
  /** Page type: 'website' for landing/section pages, 'article' for blog posts & case studies. */
  type?: 'website' | 'article';
  /** Path (relative to the site root, e.g. '/og.png') of the social-share image. */
  image?: string;
  /** ISO date the article was published (adds article:published_time + JSON-LD). */
  publishedTime?: string;
  /** ISO date the article was last updated. */
  modifiedTime?: string;
  /** Article tags / keywords. */
  tags?: string[];
  /** Emit Person + WebSite structured data (use on the home page). */
  isHome?: boolean;
  /** Prevent indexing of this page. */
  noindex?: boolean;
}

const {
  title,
  description = 'Senior Full-Stack Software Engineer — Backend, Architecture, AI-assisted development.',
  lang: langProp,
  type = 'website',
  image = '/og.png',
  publishedTime,
  modifiedTime,
  tags = [],
  isHome = false,
  noindex = false,
} = Astro.props;

const lang: Lang = langProp ?? getLangFromUrl(Astro.url);
const dir = 'ltr';
const t = useTranslations(lang);

const siteName = 'Ehsan Hosseini';
const authorName = 'Ehsan Hosseini';
const twitterHandle = ''; // set to '@handle' if you create an X/Twitter account
const sameAs = ['https://www.linkedin.com/in/seyed-ehsan-seyed-hosseini'];

// Google Search Console verification token (Settings → repo variable GOOGLE_SITE_VERIFICATION,
// or paste it directly). Google gives it to you as the content of a <meta> tag.
const googleSiteVerification = import.meta.env.PUBLIC_GOOGLE_SITE_VERIFICATION ?? '';

const fullTitle = title === siteName ? title : `${title} — ${siteName}`;
const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// --- hreflang: map the current URL to its en/de counterparts -------------------
const baseNoSlash = import.meta.env.BASE_URL.replace(/\/$/, ''); // e.g. '/Portflio'
// image is site-root-relative (e.g. '/og.png'); prefix the base so it resolves under /Portflio.
const ogImage = new URL(baseNoSlash + image, Astro.site).toString();
let logical = Astro.url.pathname;                                 // '/Portflio/de/blog/x'
if (baseNoSlash && logical.startsWith(baseNoSlash)) logical = logical.slice(baseNoSlash.length);
if (logical.startsWith('/de')) logical = logical.slice(3) || '/'; // strip locale prefix
if (!logical.startsWith('/')) logical = '/' + logical;
const enPath = baseNoSlash + (logical === '/' ? '/' : logical);
const dePath = baseNoSlash + '/de' + (logical === '/' ? '' : logical);
const alternates = [
  { hreflang: 'en', href: new URL(enPath, Astro.site).toString() },
  { hreflang: 'de', href: new URL(dePath, Astro.site).toString() },
  { hreflang: 'x-default', href: new URL(enPath, Astro.site).toString() },
];

// --- JSON-LD structured data ---------------------------------------------------
const jsonLd: Record<string, unknown>[] = [];
if (isHome) {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'Person',
    name: authorName,
    jobTitle: 'Senior Full-Stack Software Engineer',
    url: new URL(baseNoSlash + '/', Astro.site).toString(),
    image: ogImage,
    email: 'mailto:ehsan.hosseini.dev@gmail.com',
    sameAs,
    knowsAbout: ['C#', '.NET', 'Clean Architecture', 'Domain-Driven Design', 'Backend Engineering', 'RAG', 'LLM integration'],
  });
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: siteName,
    url: new URL(baseNoSlash + '/', Astro.site).toString(),
    inLanguage: lang,
  });
}
if (type === 'article') {
  jsonLd.push({
    '@context': 'https://schema.org',
    '@type': 'BlogPosting',
    headline: title,
    description,
    image: ogImage,
    inLanguage: lang,
    ...(publishedTime ? { datePublished: publishedTime } : {}),
    ...(modifiedTime ? { dateModified: modifiedTime } : {}),
    ...(tags.length ? { keywords: tags.join(', ') } : {}),
    author: { '@type': 'Person', name: authorName, url: new URL(baseNoSlash + '/', Astro.site).toString() },
    publisher: { '@type': 'Person', name: authorName },
    mainEntityOfPage: { '@type': 'WebPage', '@id': canonical },
  });
}

// Google Analytics (GA4). Paste your Measurement ID here (looks like "G-XXXXXXXXXX").
// Get one at https://analytics.google.com → Admin → Data Streams → Web.
// While empty, the tracking script is not loaded at all (e.g. local dev).
const GA_MEASUREMENT_ID = import.meta.env.PUBLIC_GA_ID ?? '';
---

<!doctype html>
<html lang={lang} dir={dir} class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href={`${import.meta.env.BASE_URL}favicon.svg`} />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <meta name="author" content={authorName} />
    {tags.length > 0 && <meta name="keywords" content={tags.join(', ')} />}
    <meta name="robots" content={noindex ? 'noindex, nofollow' : 'index, follow, max-image-preview:large'} />
    <link rel="canonical" href={canonical} />

    {/* Google Search Console verification */}
    {googleSiteVerification && <meta name="google-site-verification" content={googleSiteVerification} />}

    {/* hreflang alternates for the en/de versions of this page */}
    {alternates.map((a) => <link rel="alternate" hreflang={a.hreflang} href={a.href} />)}

    {/* Open Graph */}
    <meta property="og:type" content={type} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content={`${siteName} — ${title}`} />
    <meta property="og:locale" content={lang === 'de' ? 'de_DE' : 'en_US'} />
    <meta property="og:locale:alternate" content={lang === 'de' ? 'en_US' : 'de_DE'} />
    {type === 'article' && publishedTime && <meta property="article:published_time" content={publishedTime} />}
    {type === 'article' && modifiedTime && <meta property="article:modified_time" content={modifiedTime} />}
    {type === 'article' && <meta property="article:author" content={authorName} />}
    {type === 'article' && tags.map((tg) => <meta property="article:tag" content={tg} />)}

    {/* Twitter / X */}
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    {twitterHandle && <meta name="twitter:creator" content={twitterHandle} />}

    {/* Structured data (JSON-LD) */}
    {jsonLd.map((data) => <script type="application/ld+json" is:inline set:html={JSON.stringify(data)} />)}

    <meta name="theme-color" content="#05060f" />

    {/* Google Analytics (GA4) — only loaded when a Measurement ID is configured */}
    {GA_MEASUREMENT_ID && (
      <>
        <script is:inline async src={`https://www.googletagmanager.com/gtag/js?id=${GA_MEASUREMENT_ID}`}></script>
        <script is:inline define:vars={{ GA_MEASUREMENT_ID }}>
          window.dataLayer = window.dataLayer || [];
          function gtag() { dataLayer.push(arguments); }
          gtag('js', new Date());
          gtag('config', GA_MEASUREMENT_ID);
        </script>
      </>
    )}

    <!-- Smooth reveal-on-scroll observer (inlined to avoid an extra request) -->
    <script is:inline>
      window.addEventListener('DOMContentLoaded', () => {
        const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
        const els = document.querySelectorAll('.reveal');
        if (reduce) {
          els.forEach((el) => el.classList.add('in'));
          return;
        }
        const io = new IntersectionObserver(
          (entries) => {
            for (const e of entries) {
              if (e.isIntersecting) {
                e.target.classList.add('in');
                io.unobserve(e.target);
              }
            }
          },
          { rootMargin: '-10% 0px -10% 0px', threshold: 0.05 }
        );
        els.forEach((el) => io.observe(el));
      });
    </script>
  </head>
  <body class="grid-bg-wrapper">
    <div class="pointer-events-none fixed inset-0 grid-bg opacity-50" aria-hidden="true"></div>
    <div class="relative z-10 flex flex-col min-h-screen">
      <Navigation lang={lang} />
      <main class="flex-1">
        <slot />
      </main>
      <Footer lang={lang} />
    </div>
  </body>
</html>
