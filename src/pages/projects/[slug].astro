---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '~/layouts/BaseLayout.astro';
import { useTranslations } from '~/i18n/ui';

export async function getStaticPaths() {
  const entries = await getCollection('projects', ({ data }) => data.lang === 'en' && !data.draft);
  return entries.map((entry) => ({
    params: { slug: entry.slug },
    props: { entry },
  }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
const t = useTranslations('en');
const base = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<BaseLayout title={entry.data.title} description={entry.data.summary} lang="en">
  <article class="container-x py-16 max-w-3xl">
    <a href={`${base}/projects`} class="inline-flex items-center gap-2 text-sm text-ink-dim hover:text-neon-cyan mb-8">
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="rtl-flip">
        <path d="m12 19-7-7 7-7"/><path d="M19 12H5"/>
      </svg>
      {t('projects.back')}
    </a>

    <div class="flex flex-wrap items-center gap-2 text-xs font-mono text-ink-mute mb-4">
      {entry.data.year && <span>{entry.data.year}</span>}
      {entry.data.role && <><span class="opacity-50">·</span><span>{entry.data.role}</span></>}
    </div>

    <h1 class="font-display text-4xl sm:text-5xl font-bold leading-tight text-grad">{entry.data.title}</h1>
    <p class="text-ink-dim text-lg mt-4 leading-relaxed">{entry.data.summary}</p>

    <div class="mt-6 flex flex-wrap gap-1.5">
      {entry.data.tech.map((t) => <span class="chip text-xs">{t}</span>)}
    </div>

    <hr class="border-line my-10" />

    <div class="prose-neon">
      <Content />
    </div>

    {(entry.data.repo || entry.data.demo) && (
      <div class="mt-10 flex flex-wrap gap-3">
        {entry.data.repo && <a href={entry.data.repo} class="btn-ghost" target="_blank" rel="noreferrer">Source ↗</a>}
        {entry.data.demo && <a href={entry.data.demo} class="btn-primary" target="_blank" rel="noreferrer">Live demo ↗</a>}
      </div>
    )}
  </article>
</BaseLayout>
