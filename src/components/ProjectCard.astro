---
import type { CollectionEntry } from 'astro:content';

interface Props {
  project: CollectionEntry<'projects'>;
  href: string;
  readLabel: string;
}
const { project, href, readLabel } = Astro.props;
const { title, summary, tech, accent } = project.data;

const accentBorder: Record<string, string> = {
  cyan: 'hover:border-neon-cyan/60',
  violet: 'hover:border-neon-violet/60',
  magenta: 'hover:border-neon-magenta/60',
  lime: 'hover:border-neon-lime/60',
};
const accentText: Record<string, string> = {
  cyan: 'text-neon-cyan',
  violet: 'text-neon-violet',
  magenta: 'text-neon-magenta',
  lime: 'text-neon-lime',
};
const accentGrad: Record<string, string> = {
  cyan: 'from-neon-cyan/40 to-neon-blue/0',
  violet: 'from-neon-violet/40 to-neon-magenta/0',
  magenta: 'from-neon-magenta/40 to-neon-violet/0',
  lime: 'from-neon-lime/40 to-neon-cyan/0',
};
---

<a
  href={href}
  data-tags={[...(project.data.tags ?? []), ...tech].join(' ')}
  class={`project-card group card p-6 flex flex-col gap-4 ${accentBorder[accent] ?? ''}`}
>
  <!-- Glow corner -->
  <span
    class={`pointer-events-none absolute -top-12 -right-12 w-40 h-40 rounded-full bg-gradient-to-br ${accentGrad[accent]} blur-2xl opacity-60 group-hover:opacity-100 transition-opacity`}
    aria-hidden="true"
  ></span>

  <div class="flex items-start justify-between gap-3 relative">
    <h3 class="font-display text-xl font-semibold leading-tight">
      {title}
    </h3>
    <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class={`flex-shrink-0 ${accentText[accent]} rtl-flip opacity-60 group-hover:opacity-100 group-hover:translate-x-1 transition-all`}>
      <path d="M7 17 17 7"/>
      <path d="M7 7h10v10"/>
    </svg>
  </div>

  <p class="text-ink-dim text-sm leading-relaxed">{summary}</p>

  <div class="flex flex-wrap gap-1.5 mt-auto pt-2">
    {tech.slice(0, 6).map((t) => (
      <span class="chip text-[10px]">{t}</span>
    ))}
  </div>

  <span class={`mt-2 inline-flex items-center gap-1 text-xs font-mono ${accentText[accent]}`}>
    {readLabel} →
  </span>
</a>
