---
import { useTranslations, type Lang, type UIKey } from '~/i18n/ui';
import { skillGroups } from '~/data/skills';

interface Props { lang: Lang; }
const { lang } = Astro.props;
const t = useTranslations(lang);
---

<section id="skills" class="section">
  <div class="reveal">
    <span class="section-eyebrow">{t('skills.eyebrow')}</span>
    <h2 class="heading mt-4">{t('skills.title')}</h2>
  </div>

  <div class="mt-12 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
    {skillGroups.map((group, idx) => {
      const titleKey = `skills.${group.key}` as UIKey;
      return (
        <div class="card p-6 reveal" style={`transition-delay: ${idx * 60}ms`}>
          <div class="flex items-center gap-3 mb-4">
            <span class="font-mono text-xs text-neon-cyan">0{idx + 1}</span>
            <h3 class="font-display font-semibold text-lg">{t(titleKey)}</h3>
          </div>
          <div class="flex flex-wrap gap-1.5">
            {group.items.map((item) => (
              <span class="chip text-xs">{item}</span>
            ))}
          </div>
        </div>
      );
    })}
  </div>
</section>
